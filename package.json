{
  "name": "roon-ai-bridge",
  "version": "0.19.0",
  "description": "Roon bridge with native extension settings, advanced transport control and a secure administration portal.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test \"test/*.test.js\"",
    "widget:preview": "pnpm run build && node scripts/widget-v2-preview.js",
    "start": "node dist/index.js",
    "mcp": "node dist/bridge-v2/mcp/index.js",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "roon",
    "bridge",
    "express"
  ],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "node-roon-api": "github:roonlabs/node-roon-api",
    "node-roon-api-browse": "github:roonlabs/node-roon-api-browse",
    "node-roon-api-image": "github:roonlabs/node-roon-api-image",
    "node-roon-api-settings": "github:roonlabs/node-roon-api-settings",
    "node-roon-api-status": "github:roonlabs/node-roon-api-status",
    "node-roon-api-transport": "github:roonlabs/node-roon-api-transport",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
